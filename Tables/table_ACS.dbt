  .ThetaErrThrBRE:
    @datatype: uVector

  ."ThetaErrThrBRE.*":
    @structname: "ThetaErrThrBRE.*"

  .ThetaErrThrBRE.v[0]:
    @description: "Trans From DeltaV Att Error Thr For BRE (1)"
    @units: rad
    @default: "0.50*DBT_DEG_2_RAD"

  .ThetaErrThrBRE.v[1]:
    @description: "Trans From DeltaV Att Error Thr For BRE (2)"
    @units: rad
    @default: "0.50*DBT_DEG_2_RAD"

  .ThetaErrThrBRE.v[2]:
    @description: "Trans From DeltaV Att Error Thr For BRE (3)"
    @units: rad
    @default: "0.50*DBT_DEG_2_RAD"

  .ThetaErrThrREA:
    @datatype: uVector

  ."ThetaErrThrREA.*":
    @structname: "ThetaErrThrREA.*"

  .ThetaErrThrREA.v[0]:
    @description: "Trans From DeltaV Att Error Thr For REA (1)"
    @units: rad
    @default: "0.25*DBT_DEG_2_RAD"

  .ThetaErrThrREA.v[1]:
    @description: "Trans From DeltaV Att Error Thr For REA (2)"
    @units: rad
    @default: "0.25*DBT_DEG_2_RAD"

  .ThetaErrThrREA.v[2]:
    @description: "Trans From DeltaV Att Error Thr For REA (3)"
    @units: rad
    @default: "0.25*DBT_DEG_2_RAD"

  .OmegaErrThrBRE:
    @datatype: uVector

  ."OmegaErrThrBRE.*":
    @structname: "OmegaErrThrBRE.*"

  .OmegaErrThrBRE.v[0]:
    @description: "Trans From DeltaV Rate Error Thr For BRE (1)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .OmegaErrThrBRE.v[1]:
    @description: "Trans From DeltaV Rate Error Thr For BRE (2)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .OmegaErrThrBRE.v[2]:
    @description: "Trans From DeltaV Rate Error Thr For BRE (3)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .OmegaErrThrREA:
    @datatype: uVector

  ."OmegaErrThrREA.*":
    @structname: "OmegaErrThrREA.*"

  .OmegaErrThrREA.v[0]:
    @description: "Trans From DeltaV Rate Error Thr For REA (1)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .OmegaErrThrREA.v[1]:
    @description: "Trans From DeltaV Rate Error Thr For REA (2)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .OmegaErrThrREA.v[2]:
    @description: "Trans From DeltaV Rate Error Thr For REA (3)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .InitDeltaVTrqBiasScaleFactorBRE:
    @description: "Delta V Torque Bias Scale Factor Applied During Start of BRE Delta V"
    @datatype: float64
    @default: 0.5

  .InitDeltaVTrqBiasScaleFactorREA:
    @description: "Delta V Torque Bias Scale Factor Applied During Start of REA Delta V"
    @datatype: float64
    @default: 0.2

  .ResDeltaVTrqBiasScaleFactorBRE:
    @description: "Delta V Torque Bias Scale Factor Applied During Tailoff (Residual) of BRE Delta V"
    @datatype: float64
    @default: 1.3

  .ResDeltaVTrqBiasScaleFactorREA:
    @description: "Delta V Torque Bias Scale Factor Applied During Tailoff (Residual) of REA Delta V"
    @datatype: float64
    @default: 1.5

  .ResDeltaVIntErrScaleFactorBRE:
    @description: "Integral Error Limit Bdy State Scale Factor Applied During Residual BRE Delta V"
    @datatype: float64
    @default: 0.6

  .ResDeltaVIntErrScaleFactorREA:
    @description: "Integral Error Limit Bdy State Scale Factor Applied During Residual REA Delta V"
    @datatype: float64
    @default: 1.5

  .ResSimplexDeltaVIntErrGain:
    @description: "Tuning Parameter for the Exit Transient Scaling of Simplex Delta V Burns"
    @datatype: float64
    @default: 1

  .MinDeltaVCmdMag:
    @description: "Minimum Magnitude Delta V That Is Commanded To The Jets"
    @units: "m/sec"
    @datatype: float64
    @default: 0.001

  .MinBreDeltaVOnTime:
    @description: "Minimum Duration For A BRE Delta V"
    @units: sec
    @datatype: float64
    @default: 10

  .DeltaVTimerScaleFactor:
    @description: "Scale Factor to Adjust The Simplex Timer"
    @datatype: float64
    @default: 2

  .DeltaVTimerMinTimeEst:
    @description: "Minimum Estimated Duration For The Simplex Timer"
    @units: sec
    @datatype: float64
    @default: 72

  .Simplex:
    @datatype: ac_jet_simplex_type

  ."Simplex.*":
    @structname: "Simplex.*"

  .Simplex.UpperBoundLmt:
    @description: "Default value for UpperBounds"
    @default: 2

  ."Simplex.JetInSimplex[*]":
    @conversion: True_False
    
  .Simplex.JetInSimplex[0]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[1]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[2]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[3]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[4]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[5]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[6]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[7]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[8]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[9]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[10]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  .Simplex.JetInSimplex[11]:
    @description: "Flag To Include Jet In Simplex"
    @default: True

  ."Simplex.InitialBasisVariables[*]": @conversion: ac_jet_id
  
  .Simplex.InitialBasisVariables[0]:
    @default: REA1

  .Simplex.InitialBasisVariables[1]:
    @default: REA2

  .Simplex.InitialBasisVariables[2]:
    @default: REA3

  .Simplex.InitialBasisVariables[3]:
    @default: REA4

  .Simplex.InitialBasisVariables[4]:
    @default: REA8

  .Simplex.InitialBasisVariables[5]:
    @default: REA10

  ."Simplex.InitialNonBasisVariables[*]": @conversion: ac_jet_id
    
  .Simplex.InitialNonBasisVariables[0]:
    @default: REA5

  .Simplex.InitialNonBasisVariables[1]:
    @default: REA6

  .Simplex.InitialNonBasisVariables[2]:
    @default: REA7

  .Simplex.InitialNonBasisVariables[3]:
    @default: REA9

  .Simplex.InitialNonBasisVariables[4]:
    @default: REA11

  .Simplex.InitialNonBasisVariables[5]:
    @default: REA12

  .Simplex.InitialNonBasisVariables[6]:
    @default: BRE13

  .Simplex.InitialNonBasisVariables[7]:
    @default: BRE14

  .Simplex.SimplexIterationLmt:
    @description: "Simplex Iteration Limit"
    @default: 100

  .Simplex.SpareWord:
    @default: 0
}

