  .OmegaErrThrREA.v[2]:
    @description: "Trans From DeltaV Rate Error Thr For REA (3)"
    @units: "rad/sec"
    @default: "0.05*DBT_DEG_2_RAD"

  .InitDeltaVTrqBiasScaleFactorBRE:
    @description: "Delta V Torque Bias Scale Factor Applied During Start of BRE Delta V"
    @datatype: float64
    @default: 0.5

  .InitDeltaVTrqBiasScaleFactorREA:
    @description: "Delta V Torque Bias Scale Factor Applied During Start of REA Delta V"
    @datatype: float64
    @default: 0.2

  .ResDeltaVTrqBiasScaleFactorBRE:
    @description: "Delta V Torque Bias Scale Factor Applied During Tailoff (Residual) of BRE Delta V"
    @datatype: float64
    @default: 1.3

  .ResDeltaVTrqBiasScaleFactorREA:
    @description: "Delta V Torque Bias Scale Factor Applied During Tailoff (Residual) of REA Delta V"
    @datatype: float64
    @default: 1.5

  .ResDeltaVIntErrScaleFactorBRE:
    @description: "Integral Error Limit Bdy State Scale Factor Applied During Residual BRE Delta V"
    @datatype: float64
    @default: 0.6

  .ResDeltaVIntErrScaleFactorREA:
    @description: "Integral Error Limit Bdy State Scale Factor Applied During Residual REA Delta V"
    @datatype: float64
    @default: 1.5

  .ResSimplexDeltaVIntErrGain:
    @description: "Tuning Parameter for the Exit Transient Scaling of Simplex Delta V Burns"
    @datatype: float64
    @default: 1

  .MinDeltaVCmdMag:
    @description: "Minimum Magnitude Delta V That Is Commanded To The Jets"
    @units: "m/sec"
    @datatype: float64
    @default: 0.001

  .MinBreDeltaVOnTime:
    @description: "Minimum Duration For A BRE Delta V"
    @units: sec
    @datatype: float64
    @default: 10

  .DeltaVTimerScaleFactor:
    @description: "Scale Factor to Adjust The Simplex Timer"
    @datatype: float64
    @default: 2

  .DeltaVTimerMinTimeEst:
    @description: "Minimum Estimated Duration For The Simplex Timer"
    @units: sec
    @datatype: float64
    @default: 72
	
  .DeltaVRemainingCLoopPinvBreThr:
    @description: "Remaining DeltaV Threshold for CLoop PINV BRE Burns"
    @units: "m/sec"
    @datatype: float64
    @default: 0.01

  .SimplexTorqueSlewLmt:
    @datatype: float64
    @default: 2.25

  .PseudoInvTorqueSlewLmt:
    @datatype: float64
    @default: 0.63302

  .MaxBurnDurationSF:
    @datatype: float64
    @default: 2	

  .Simplex:
    @datatype: Simplex_type

  ."Simplex.*":
    @structname: "Simplex.*"

  .Simplex.UpperBoundLmt:
    @description: "Default value for UpperBounds"
    @default: 2

  .Simplex.ForceScaleFactorDefaultCost:
    @default: -10.0

  .Simplex.TorqueScaleFactorDefaultCost:
    @default: -10.0

  .Simplex.ForceCmdBdyLmt:
    @default: 7.2

  ."Simplex.JetInSimplex[*]":
