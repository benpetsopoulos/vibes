table AcSolarTable {
  @description: "Solar Ephemeris Parameter Table (Coefficients From 1997 Astronomical Almanac)"
  @buildstruct!
  @fsw.component: ACSOLARTABLE
  @id: 19

  .SMSE0:
    @description: "Inclination Of Ecliptic Equation Coefficient (rad)"
    @units: rad
    @datatype: float64
    @default: "23.439279  * DBT_DEG_2_RAD"

  .SMSE1:
    @description: "Inclination Of Ecliptic Equation Frequency Constant (rad/day)"
    @units: "rad/day"
    @datatype: float64
    @default: "0.00000040 * DBT_DEG_2_RAD"

  .SMMA1:
    @description: "Mean Anomaly Equation Coefficient (rad)"
    @units: rad
    @datatype: float64
    @default: "357.528    * DBT_DEG_2_RAD"

  .SMMA2:
    @description: "Mean Anomaly Equation Frequency Constant (rad/day)"
    @units: "rad/day"
    @datatype: float64
    @default: "0.9856003  * DBT_DEG_2_RAD"

  .SMML1:
    @description: "Mean Longitude Equation Coefficient (rad)"
    @units: "rad"
    @datatype: float64
    @default: "280.460    * DBT_DEG_2_RAD"

  .SMML2:
    @description: "Mean Longitude Equation Frequency Coefficient (rad/day)"
    @units: "rad/day"
    @datatype: float64
    @default: "0.9856474  * DBT_DEG_2_RAD"

  .SMEL1:
    @description: "Mean Longitude Correction Equation Coefficient (rad)"
    @units: rad
    @datatype: float64
    @default: "1.915      * DBT_DEG_2_RAD"

  .SMEL2:
    @description: "Mean Longitude Correction Equation Coefficient (rad)"
    @units: rad
    @datatype: float64
    @default: "0.020      * DBT_DEG_2_RAD"

  .SMGPL:
    @description: "General Precession In Longitude At J2000.0 (rad/day)"
    @units: "rad/day"
    @datatype: float64
    @default: "5028.7800  * DBT_ARCSEC_2_RAD / DBT_CENTURY_2_DAY"

  .SMR1:
    @description: "Distance From Earth To Sun Coefficient (a.u.)"
    @units: au
    @datatype: float64
    @default: 1.00014

  .SMR2:
    @description: "Distance From Earth To Sun Coefficient (a.u.)"
    @units: au
    @datatype: float64
    @default: 0.01671

  .SMR3:
    @description: "Distance From Earth To Sun Coefficient (a.u.)"
    @units: m
    @datatype: float64
    @default: 0.00014

  .RS0:
    @description: "Nominal Earth To Sun Distance (m)"
    @units: cnt
    @datatype: float64
    @default: 149597871465.6

  .ComputeVelocityCnt:
    @description: "Sun Velocity Computation Period"
    @units: cnt
    @datatype: sint32
    @default: 30

  .SpareDword:
    @description: Spare
    @datatype: sint32
    @default: 0
}

